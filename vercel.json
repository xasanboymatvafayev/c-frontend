{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/public/static/$1" },
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/game/aviator", "dest": "/api/index.py" },
    { "src": "/game/apple", "dest": "/api/index.py" },
    { "src": "/game/mines", "dest": "/api/index.py" },
    { "src": "/game/history", "dest": "/api/index.py" },
    { "src": "/game/profile", "dest": "/api/index.py" },
    { "src": "/game", "dest": "/api/index.py" },
    { "src": "/admin", "dest": "/api/index.py" },
    { "src": "/", "dest": "/api/index.py" }
  ],
  "env": {
    "BACKEND_URL": "@backend_url"
  }
}
